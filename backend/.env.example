# Database
DB_URL=jdbc:postgresql://localhost:5432/keyforge
DB_USERNAME=keyforge_user
DB_PASSWORD=keyforge_pass

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
SQL_LOG_LEVEL=WARN

# JWT - generate a strong random 256-bit+ secret for production
JWT_SECRET=this-is-a-dev-only-secret-key-please-override-in-prod-min-256-bits
JWT_EXPIRATION_MS=86400000

# Server
SERVER_PORT=8080

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200

LOG_LEVEL=INFO
